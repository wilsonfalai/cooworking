datasource db {
  provider = "postgresql"
  schemas  = ["cooworking2"]
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// ─── Auth Tables (better-auth compatible structure) ───────────────────────────

model User {
  id            String       @id
  name          String
  email         String       @unique
  emailVerified Boolean
  image         String?
  role          PlatformRole @default(USER)
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]
  members       Member[]

  @@map("user")
  @@schema("cooworking2")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@schema("cooworking2")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
  @@schema("cooworking2")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
  @@schema("cooworking2")
}

// ─── Domain Enums ────────────────────────────────────────────────────────────

enum PlatformRole {
  PLATFORM_ADMIN
  USER

  @@schema("cooworking2")
}

enum MemberRole {
  OWNER
  ADMIN
  STAFF
  MEMBER

  @@schema("cooworking2")
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING

  @@schema("cooworking2")
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL

  @@schema("cooworking2")
}

enum LocationStatus {
  ACTIVE
  INACTIVE

  @@schema("cooworking2")
}

// ─── Multi-Tenant Core ───────────────────────────────────────────────────────

model Organization {
  id        String             @id @default(uuid())
  name      String
  slug      String             @unique
  logo      String?
  status    OrganizationStatus @default(TRIAL)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  locations Location[]
  members   Member[]

  @@map("organization")
  @@schema("cooworking2")
}

model Location {
  id             String         @id @default(uuid())
  organizationId String
  name           String
  slug           String
  address        String?
  city           String?
  state          String?
  country        String?        @default("BR")
  zipCode        String?
  phone          String?
  timezone       String         @default("America/Sao_Paulo")
  status         LocationStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  members      Member[]

  @@unique([organizationId, slug])
  @@map("location")
  @@schema("cooworking2")
}

// ─── Members (better-auth inspired) ─────────────────────────────────────────

model Member {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  locationId     String
  role           MemberRole   @default(MEMBER)
  status         MemberStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([userId, locationId])
  @@map("member")
  @@schema("cooworking2")
}
